# Required settings
# Required. Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Required. Comma-separated Telegram user IDs allowed to control the bot.
TELEGRAM_ALLOWED_USER_IDS=

# Optional settings
# Optional. Channel/supergroup chat ID that receives copied final Codex responses.
# Usually a negative ID such as -1001234567890. The bot must be able to post there.
TELEGRAM_CHANNEL_ID=

# Optional. Codex API key. If empty, TeleCodex uses Codex CLI auth state.
CODEX_API_KEY=

# Optional. Default Codex model slug, for example gpt-5.3-codex.
CODEX_MODEL=

# Optional. Max Telegram-ingested file size in bytes.
MAX_FILE_SIZE=20971520

# Optional. Codex sandbox mode: read-only, workspace-write, or danger-full-access.
CODEX_SANDBOX_MODE=workspace-write

# Optional. Codex approval policy: never, on-request, on-failure, or untrusted.
# Use "never" for unattended/headless service operation.
CODEX_APPROVAL_POLICY=never

# Optional. Recommended. Use Codex app-server for turns, compact, tool streaming, and approvals.
# Set false only as a legacy SDK fallback.
ENABLE_CODEX_APP_SERVER_RUNTIME=true

# Optional. Run TeleCodex auto compact after Codex auto-compact events or context threshold hits.
AUTO_COMPACT_ENABLED=true

# Optional. Context usage ratio that triggers TeleCodex auto compact after a turn.
# Accepts ratios such as 0.80 or percentages such as 80.
AUTO_COMPACT_CONTEXT_THRESHOLD=0.80

# Optional. When Codex app-server auto compact is observed, run CLI PTY /compact after the turn.
AUTO_COMPACT_AFTER_CODEX_AUTO_COMPACT=true

# Optional. Check the context threshold after every completed turn.
# If false, threshold checks respect AUTO_COMPACT_COOLDOWN_*.
AUTO_COMPACT_AFTER_EVERY_TURN=false

# Optional. Threshold-based auto compact cooldown.
# Codex auto compact events bypass this. AUTO_COMPACT_AFTER_EVERY_TURN=true bypasses this for checks only.
AUTO_COMPACT_COOLDOWN_TURNS=3
AUTO_COMPACT_COOLDOWN_MINUTES=10

# Optional. Extra /launch_profiles JSON. safetyPolicy may be "restrict" or "full".
# Example: [{"id":"review","label":"Review","sandboxMode":"workspace-write","approvalPolicy":"on-request"}]
CODEX_LAUNCH_PROFILES_JSON=

# Optional. Default launch profile id.
CODEX_DEFAULT_LAUNCH_PROFILE=default

# Optional. Set true to expose danger-full-access launch profiles, including Restrict and Full.
ENABLE_UNSAFE_LAUNCH_PROFILES=false

# Optional. Tool message verbosity: all, summary, errors-only, or none.
TOOL_VERBOSITY=summary

# Optional. Show per-turn token usage footer in final Telegram replies.
SHOW_TURN_TOKEN_USAGE=false

# Optional. Allow /login and /logout from Telegram.
ENABLE_TELEGRAM_LOGIN=true

# Optional. Add Telegram reactions while processing and on success.
ENABLE_TELEGRAM_REACTIONS=false

# Optional. Telegram reaction emojis. Set to none/off/false to disable one reaction.
TELEGRAM_REACTION_PROCESSING_EMOJI=👀
TELEGRAM_REACTION_SUCCESS_EMOJI=👍
TELEGRAM_REACTION_FAILURE_EMOJI=

# Optional. Send service start/stop notifications to allowed users and TELEGRAM_CHANNEL_ID.
ENABLE_LIFECYCLE_NOTIFICATIONS=false

# Optional. Used only for voice transcription fallback, not Codex.
OPENAI_API_KEY=

# Optional. Normally leave empty: systemd units set this automatically.
# Set manually only when running without systemd and you need /service_update to target this instance.
TELECODEX_INSTANCE=

# Docker-only optional. Host Codex home directory mounted into the container.
# Compose masks auth.json with .telecodex/docker-empty-auth.json.
CODEX_HOME_DIR=./.codex

# Docker-only optional. Host path mounted for Codex file access.
# For docker-compose.local.yml, omit this to mount ${HOME}, or set an explicit host path.
TELECODEX_WORKSPACE_DIR=./workspace

# Docker-only optional. Container path for the workspace mount.
TELECODEX_CONTAINER_WORKSPACE=/workspace

# Docker-only optional. The default Dockerfile is the normal image.
# Use docker-compose.local.yml with Dockerfile.local when this environment needs brew-parity tools.
